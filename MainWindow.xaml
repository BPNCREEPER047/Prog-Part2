<Window x:Class="ProgPart2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProgPart2"
        mc:Ignorable="d"
        Title="SA Cyber Safety Assistant" 
        Height="650" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Window.Resources>
        <DataTemplate x:Key="MessageTemplate">
            <Border CornerRadius="10" 
                    Margin="5,3,5,3"
                    Padding="10,8"
                    Background="{Binding BackgroundColor}"
                    HorizontalAlignment="{Binding Alignment}">
                <StackPanel MaxWidth="500">
                    <TextBlock Text="{Binding Sender}" 
                               FontWeight="Bold" 
                               FontSize="11"
                               Foreground="#aaa"
                               Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding Text}" 
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="White"/>
                    <TextBlock Text="{Binding Timestamp}" 
                               FontSize="9"
                               Foreground="#aaa"
                               HorizontalAlignment="Right"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Welcome Page -->
        <Grid x:Name="name_grid" 
              Visibility="Visible" 
              Background="#1a1a2e">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Logo Area - Made more prominent -->
            <Border Grid.Row="0" 
                    Background="#0f3460" 
                    Margin="0,0,0,20"
                    CornerRadius="0,0,20,20"
                    Padding="20,15">
                <StackPanel>
                    <Image x:Name="LogoImage" 
                           Width="100" 
                           Height="100"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>
                    <TextBlock Text="SA Cyber Safety Assistant" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="#00b4d8"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,5"/>
                    <TextBlock Text="Helping South Africans stay safe online" 
                               FontSize="13" 
                               Foreground="#aaa"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Welcome Text -->
            <TextBlock Grid.Row="1" 
                       Text="Hi there! What should I call you?" 
                       FontSize="16" 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,30,0,20"/>

            <!-- Name Input TextBox -->
            <TextBox x:Name="user_name" 
                     Grid.Row="2"
                     Height="45"
                     Width="350"
                     FontSize="14"
                     Background="#16213e"
                     Foreground="White"
                     BorderBrush="#0f3460"
                     BorderThickness="1"
                     Padding="12,8"
                     HorizontalAlignment="Center"
                     KeyDown="UserName_KeyDown"/>

            <!-- Submit Button -->
            <Button x:Name="submitButton"
                    Grid.Row="3"
                    Height="50"
                    Width="200"
                    Margin="0,20,0,0"
                    Content="Let's Go"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#00b4d8"
                    Foreground="White"
                    Click="submit_name"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- ASCII Art -->
            <TextBlock Grid.Row="4" 
                       Text="
    ╔══════════════════════════════════════════════════════════════╗
    ║                     🛡️ CYBER SAFETY 🛡️                       ║
    ║                                                              ║
    ║      🇿🇦  PROTECTING SOUTH AFRICA FROM CYBER THREATS   🇿🇦     ║
    ║                                                              ║
    ║  • Phishing Scams     • Password Safety    • Online Privacy  ║
    ║  • Smishing/Vishing   • Social Engineering • Data Protection ║
    ║                                                              ║
    ╚══════════════════════════════════════════════════════════════╝"
                       FontFamily="Consolas"
                       FontSize="9"
                       Foreground="#4a4e69"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,20"/>
        </Grid>

        <!-- Chat Page -->
        <Grid x:Name="chats_grid" 
              Visibility="Hidden"
              Background="#1a1a2e">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Chat Header -->
            <Border Grid.Row="0" 
                    Background="#0f3460" 
                    Padding="15,10"
                    CornerRadius="0,0,15,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="ChatLogoImage" 
                           Grid.Column="0" 
                           Width="40" 
                           Height="40"
                           Stretch="Uniform"
                           Margin="0,0,10,0"/>

                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="ChatTitle" 
                                   Text="Cyber Safety Assistant" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#00b4d8"/>
                        <TextBlock x:Name="UserNameDisplay" 
                                   Text="" 
                                   FontSize="11" 
                                   Foreground="#aaa"/>
                    </StackPanel>

                    <Button x:Name="ClearChatButton"
                            Grid.Column="2"
                            Width="35"
                            Height="35"
                            Content="🗑️"
                            FontSize="16"
                            Background="#dc3545"
                            Foreground="White"
                            Cursor="Hand"
                            Click="ClearChatButton_Click"
                            ToolTip="Clear Chat">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <!-- Chat ListView -->
            <ListView x:Name="chats" 
                      Grid.Row="1"
                      Background="#1a1a2e"
                      BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Margin="10,10,10,10">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" 
                                Margin="5,3,5,3"
                                Padding="10,8"
                                Background="{Binding BackgroundColor}"
                                HorizontalAlignment="{Binding Alignment}">
                            <StackPanel MaxWidth="500">
                                <TextBlock Text="{Binding Sender}" 
                                           FontWeight="Bold" 
                                           FontSize="11"
                                           Foreground="#aaa"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding Text}" 
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding Timestamp}" 
                                           FontSize="9"
                                           Foreground="#aaa"
                                           HorizontalAlignment="Right"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Input Area -->
            <Border Grid.Row="2" 
                    Background="#16213e" 
                    Padding="15,12"
                    BorderBrush="#0f3460"
                    BorderThickness="0,2,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="question" 
                             Grid.Column="0"
                             Height="45"
                             FontSize="13"
                             Background="#1a1a2e"
                             Foreground="White"
                             BorderBrush="#0f3460"
                             BorderThickness="1"
                             Padding="12,8"
                             VerticalContentAlignment="Center"
                             KeyDown="Question_KeyDown"/>

                    <Button x:Name="sendButton"
                            Grid.Column="1"
                            Height="45"
                            Width="80"
                            Margin="10,0,0,0"
                            Content="Send"
                            FontSize="13"
                            FontWeight="Bold"
                            Background="#00b4d8"
                            Foreground="White"
                            Click="send"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>